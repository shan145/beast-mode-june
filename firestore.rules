rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Any authenticated group member can read everything
    match /{document=**} {
      allow read: if request.auth != null;
    }
    // Users can only write their own profile
    match /users/{userId} {
      allow write: if request.auth.uid == userId;
    }
    // Users can only write their own goals
    match /goals/{goalId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }
    // Users can only write their own completions
    match /completions/{completionId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }
    // Users can only write their own posts
    match /posts/{postId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }
    // Users can only write their own comments
    match /comments/{commentId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }
    // Reactions: toggle by anyone authenticated, only on own reactions
    match /reactions/{reactionId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }
    // Kudos: anyone can give kudos, but only as themselves
    match /kudos/{kudosId} {
      allow create: if request.auth.uid == request.resource.data.fromUserId;
      allow delete: if request.auth.uid == resource.data.fromUserId;
    }
  }
}
